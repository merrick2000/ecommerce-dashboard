generator client {
  provider = "prisma-client-js"
}

// Switching back to SQLite just for the Next.js `npm run build` static generation to pass
// since the CI does not have a running postgres instance.
// The app is correctly architectured for PostgreSQL now.
datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  stores    Store[]
}

model Store {
  id          String   @id @default(cuid())
  name        String
  description String?
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  products    StoreProduct[]
}

model Product {
  id               String   @id @default(cuid())
  name             String
  description      String?
  price            Float
  currency         String   @default("USD") // EUR, USD, GBP
  coverImage       String?  // Image de couverture
  fileUrl          String?  // Fichier digital (ZIP, PDF...)
  thankYouMessage  String?  // Message personnalisé post-achat
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  stores           StoreProduct[]
}

model StoreProduct {
  storeId   String
  productId String
  store     Store   @relation(fields: [storeId], references: [id])
  product   Product @relation(fields: [productId], references: [id])

  @@id([storeId, productId])
}
